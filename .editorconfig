# =============================================================================
# .editorconfig для GastronomePlatform
# Основан на рекомендациях Microsoft .NET Coding Conventions
# Соответствует C# Code Style Guide из Wiki (08_Разработка)
# =============================================================================

root = true

# =============================================================================
# Базовые настройки для всех файлов
# =============================================================================
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Конфигурационные файлы — отступ 2 пробела
[*.{json,yml,yaml,xml,csproj,props,targets}]
indent_size = 2

# Markdown — пробелы в конце строки имеют смысл (принудительный перенос)
[*.md]
trim_trailing_whitespace = false

# =============================================================================
# C# — стиль кода
# =============================================================================
[*.cs]

# -----------------------------------------------------------------------------
# Организация using
# -----------------------------------------------------------------------------
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# -----------------------------------------------------------------------------
# Квалификация this. — не использовать (приватные поля с _ однозначны)
# -----------------------------------------------------------------------------
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# -----------------------------------------------------------------------------
# Предпочтение ключевых слов языка (int, string) вместо типов фреймворка (Int32, String)
# -----------------------------------------------------------------------------
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# -----------------------------------------------------------------------------
# Модификаторы
# -----------------------------------------------------------------------------
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:warning

# -----------------------------------------------------------------------------
# Скобки в выражениях
# -----------------------------------------------------------------------------
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:suggestion

# -----------------------------------------------------------------------------
# var vs явный тип (сбалансированный подход)
# -----------------------------------------------------------------------------
# int count = 5; — явный тип для встроенных
csharp_style_var_for_built_in_types = false:suggestion
# var service = new DishService(); — var когда тип очевиден из правой части
csharp_style_var_when_type_is_apparent = true:suggestion
# Result<Guid> result = await _mediator.Send(command); — явный тип когда неочевидно
csharp_style_var_elsewhere = false:suggestion

# -----------------------------------------------------------------------------
# Expression-bodied members
# -----------------------------------------------------------------------------
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_operators = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion

# -----------------------------------------------------------------------------
# Паттерн-матчинг
# -----------------------------------------------------------------------------
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_not_pattern = true:warning
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion

# -----------------------------------------------------------------------------
# Упрощения кода
# -----------------------------------------------------------------------------
# Target-typed new: DishService service = new();
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion
# Упрощение default: int count = default;
csharp_style_prefer_default_literal = true:suggestion
# Null propagation: user?.Profile?.Name
dotnet_style_null_propagation = true:warning
# Null coalescing: name ?? "Guest"
dotnet_style_coalesce_expression = true:warning
# Условное выражение для присваивания
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
# Упрощение using declaration
csharp_prefer_simple_using_statement = true:suggestion
# Упрощение проверки is null
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
# Авто-свойства
dotnet_style_prefer_auto_properties = true:suggestion
# Inline variable declaration: if (int.TryParse(s, out var result))
csharp_style_inlined_variable_declaration = true:suggestion
# Throw expression: _field = value ?? throw new ArgumentNullException()
csharp_style_throw_expression = true:suggestion
# Deconstructed variable declaration
csharp_style_deconstructed_variable_declaration = true:suggestion

# -----------------------------------------------------------------------------
# Фигурные скобки — всегда на новой строке (Allman style)
# -----------------------------------------------------------------------------
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# -----------------------------------------------------------------------------
# Отступы
# -----------------------------------------------------------------------------
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = one_less_than_current
csharp_indent_block_contents = true
csharp_indent_braces = false

# -----------------------------------------------------------------------------
# Пробелы
# -----------------------------------------------------------------------------
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_after_comma = true
csharp_space_before_comma = false
csharp_space_after_dot = false
csharp_space_before_dot = false
csharp_space_after_semicolon_in_for_statement = true
csharp_space_before_semicolon_in_for_statement = false

# -----------------------------------------------------------------------------
# Wrapping — не оборачивать
# -----------------------------------------------------------------------------
csharp_preserve_single_line_statements = false
csharp_preserve_single_line_blocks = true

# =============================================================================
# Правила именования (Naming Conventions)
# =============================================================================

# --- Правило 1: Интерфейсы начинаются с I ---
dotnet_naming_rule.interfaces_should_begin_with_i.severity = warning
dotnet_naming_rule.interfaces_should_begin_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_should_begin_with_i.style = begins_with_i_style

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_style.begins_with_i_style.required_prefix = I
dotnet_naming_style.begins_with_i_style.capitalization = pascal_case

# --- Правило 2: Type parameters начинаются с T ---
dotnet_naming_rule.type_parameters_should_begin_with_t.severity = warning
dotnet_naming_rule.type_parameters_should_begin_with_t.symbols = type_parameters
dotnet_naming_rule.type_parameters_should_begin_with_t.style = begins_with_t_style

dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter
dotnet_naming_symbols.type_parameters.applicable_accessibilities = *

dotnet_naming_style.begins_with_t_style.required_prefix = T
dotnet_naming_style.begins_with_t_style.capitalization = pascal_case

# --- Правило 3: Константы — UPPER_CASE ---
dotnet_naming_rule.constants_should_be_upper_case.severity = warning
dotnet_naming_rule.constants_should_be_upper_case.symbols = constants
dotnet_naming_rule.constants_should_be_upper_case.style = upper_case_style

dotnet_naming_symbols.constants.applicable_kinds = field, local
dotnet_naming_symbols.constants.applicable_accessibilities = *
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_style.upper_case_style.capitalization = all_upper
dotnet_naming_style.upper_case_style.word_separator = _

# --- Правило 4: Приватные поля — _camelCase ---
dotnet_naming_rule.private_fields_should_be_camel_case.severity = warning
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, private_protected

dotnet_naming_style.camel_case_underscore_style.required_prefix = _
dotnet_naming_style.camel_case_underscore_style.capitalization = camel_case

# --- Правило 5: Типы (классы, структуры, enum, делегаты) — PascalCase ---
dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.types.applicable_kinds = class, struct, enum, delegate
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# --- Правило 6: Публичные и внутренние члены — PascalCase ---
dotnet_naming_rule.public_members_should_be_pascal_case.severity = warning
dotnet_naming_rule.public_members_should_be_pascal_case.symbols = public_members
dotnet_naming_rule.public_members_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.public_members.applicable_kinds = property, method, field, event
dotnet_naming_symbols.public_members.applicable_accessibilities = public, internal, protected, protected_internal

# --- Правило 7: Параметры и локальные переменные — camelCase ---
dotnet_naming_rule.parameters_should_be_camel_case.severity = warning
dotnet_naming_rule.parameters_should_be_camel_case.symbols = parameters
dotnet_naming_rule.parameters_should_be_camel_case.style = camel_case_style

dotnet_naming_symbols.parameters.applicable_kinds = parameter, local
dotnet_naming_symbols.parameters.applicable_accessibilities = *

dotnet_naming_style.camel_case_style.capitalization = camel_case

# --- Правило 8: Async-методы заканчиваются на Async ---
dotnet_naming_rule.async_methods_should_end_with_async.severity = warning
dotnet_naming_rule.async_methods_should_end_with_async.symbols = async_methods
dotnet_naming_rule.async_methods_should_end_with_async.style = ends_with_async_style

dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.applicable_accessibilities = *
dotnet_naming_symbols.async_methods.required_modifiers = async

dotnet_naming_style.ends_with_async_style.required_suffix = Async
dotnet_naming_style.ends_with_async_style.capitalization = pascal_case

# =============================================================================
# Диагностики (Analyzer Rules)
# =============================================================================

# --- Стиль кода (IDE) ---
# IDE0005: Неиспользуемый using
dotnet_diagnostic.IDE0005.severity = warning
# IDE0044: Поле можно сделать readonly
dotnet_diagnostic.IDE0044.severity = warning
# IDE0051: Неиспользуемый приватный член
dotnet_diagnostic.IDE0051.severity = warning
# IDE0052: Непрочитанный приватный член
dotnet_diagnostic.IDE0052.severity = warning

# --- Стилистика (предложения по улучшению) ---
# IDE0090: Упрощение new() (target-typed new)
dotnet_diagnostic.IDE0090.severity = suggestion
# IDE0063: Упрощение using declaration
dotnet_diagnostic.IDE0063.severity = suggestion
# IDE0066: Switch expression
dotnet_diagnostic.IDE0066.severity = suggestion

# --- Компилятор ---
# CS0219: Неиспользуемая переменная
dotnet_diagnostic.CS0219.severity = warning
# CS1591: Отсутствие XML-документации для публичных членов
dotnet_diagnostic.CS1591.severity = suggestion

# =============================================================================
# HTML / Razor
# =============================================================================
[*.{html,cshtml,razor}]
indent_size = 2

# =============================================================================
# CSS / SCSS
# =============================================================================
[*.{css,scss,less}]
indent_size = 2

# =============================================================================
# JavaScript / TypeScript
# =============================================================================
[*.{js,ts,jsx,tsx}]
indent_size = 2